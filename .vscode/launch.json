{
  "configurations": [
    {
      "name": "Debug Program",
      "type": "codelldb",
      "request": "launch",
      "program": "${command:cmake.launchTargetPath}",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "setupCommands": [
        {
          "description": "Включаем pretty-printing для gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ],
      "preLaunchTask": "CMake: Build",
      "miDebuggerPath": "/usr/bin/gdb"
    }
  ]
}
