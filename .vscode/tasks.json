{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CMake: Build",
      "type": "shell",
      "command": "scripts/build.sh",
      "use_terminal": true,
      "close_on_exit": false,
      "args": [
        "--target=pas-cli",
        "--preset=${input:buildType}"
      ],
      "group": "build",
      "detail": "Сборка проекта"
    },
    {
      "label": "Run Program",
      "type": "shell",
      "command": "${workspaceFolder}/build/${input:buildType}/${workspaceFolderBasename}",
      "group": "test",
      "problemMatcher": [],
      "detail": "Запуск собранной программы"
    },
    {
      "label": "CMake: Test",
      "type": "shell",
      "command": "scripts/run_tests.sh",
      "args": [
        "--preset=${input:buildType}"
      ],
      "group": "test",
      "detail": "Запуск тестов"
    },
    {
      "label": "CMake: Benchmark",
      "type": "shell",
      "command": "scripts/run_benchmarks.sh",
      "args": [
        "--preset=${input:buildType}"
      ],
      "group": "test",
      "detail": "Запуск бенчмарка"
    }
  ],
  "inputs": [
    {
      "id": "buildType",
      "type": "pickString",
      "description": "Выберите тип сборки",
      "options": [
        "debug",
        "release"
      ],
      "default": "debug"
    }
  ]
}
